{
  "skills": [
    "shadcn/ui"
  ],
  "mcpServers": {
    "shadcn": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "shadcn@latest",
        "mcp"
      ]
    },
    "figma": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "figma-developer-mcp",
        "--figma-api-key=",
        "--stdio"
      ],
      "env": {
      }
    },
    "obsidian": {
      "type": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "./scripts/obsidian-mcp.ps1"
      ]
    }
  }
}
